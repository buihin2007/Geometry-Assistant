# ===== LLM (xem PLAN §4.1 / §13) =====
# Bọc sau interface chung — đổi provider không sửa logic.
LLM_PROVIDER=gemini            # gemini | groq | openrouter | mock
LLM_API_KEY=                   # key Google AI Studio cho mặc định v1
LLM_MODEL=gemini-2.5-flash     # model Gemini có vision

# Tùy chọn tách provider để tiết kiệm quota (để trống = dùng LLM_* ở trên)
GENERATOR_PROVIDER=            # vd: groq (nhanh/rẻ, text) cho khâu sinh lệnh
GENERATOR_MODEL=
GENERATOR_API_KEY=
REVIEWER_PROVIDER=            # provider có vision cho review (mặc định = LLM_PROVIDER)
REVIEWER_MODEL=
REVIEWER_API_KEY=

ENABLE_REVIEW=true
MAX_FIX_ROUNDS=3
MAX_LLM_CALLS_PER_REQUEST=8

# Kiến trúc dựng hình: planner (LLM chọn primitive) → compiler tất định từ template
# đã verify (THCS_construction_library_spec). false = dùng generator sinh lệnh thô.
USE_PLANNER=true
ENABLE_ANALYSIS=true

# ===== Supabase =====
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===== Services =====
# URL Node GeoGebra service mà orchestrator gọi
GGB_SERVICE_URL=http://ggb-service:8081
# Port mỗi service
ORCHESTRATOR_PORT=8080
GGB_SERVICE_PORT=8081

# ===== Demo gating =====
DEMO_LIMIT_PER_IP=2            # vĩnh viễn, không reset

# ===== Frontend (Vite) — tiền tố VITE_ để lộ ra client =====
VITE_API_URL=http://localhost:8080
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
